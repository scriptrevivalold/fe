local ReplicationService = {}
ReplicationService.__index = ReplicationService

-- DEFINITIONS --

local runservice = game:GetService("RunService")
local core = script:WaitForChild("CORE")

local runtime_folder = core:WaitForChild("ReplicationRuntime")
local security_libraries = core:WaitForChild("SecurityLibraries")

if runservice:IsClient() then
	error("Replication management can only be handled by game server")
end

-- SERVER FUNCTIONS --

function ReplicationService:ReplicatePropertyFromClient(instance: "instance", property: "string", player: "instance")
	local replicator = core:WaitForChild("Replication"):Clone()
	replicator.Parent = runtime_folder
	replicator.Instance.Value = instance
	replicator.Player.Value = player
	replicator.Property.Value = property
	replicator.Secure.Value = false
	replicator.CoreFolder.Value = core

	return require(replicator) --require(core:WaitForChild("Replication"))
end

function ReplicationService:ReplicatePropertyFromClientWithSecurity(instance: "instance", property: "string", player: "instance", securitylibrary: "string")	
	local replicator = core:WaitForChild("Replication"):Clone()
	replicator.Parent = runtime_folder
	replicator.Instance.Value = instance
	replicator.Player.Value = player
	replicator.Property.Value = property
	replicator.Secure.Value = true
	replicator.SecurityLibrary.Value = security_libraries:FindFirstChild(securitylibrary)
	replicator.CoreFolder.Value = core

	return require(replicator) --require(core:WaitForChild("Replication"))
end

function ReplicationService:GetAllReplicatorsOnInstance(instance: "instance")
	local replicators = {}
	for i, v in runtime_folder:GetChildren() do
		if v.Instance.Value == instance then
			table.insert(replicators, require(v))
		end
	end
	return replicators
end

function ReplicationService:GetAllReplicatorsFromPlayer(player: "instance")
	local replicators = {}
	for i, v in runtime_folder:GetChildren() do
		if v.Player.Value == player then
			table.insert(replicators, require(v))
		end
	end
	return replicators
end

function ReplicationService:GetAllReplicators()
	local replicators = {}
	for i, v in runtime_folder:GetChildren() do
		table.insert(replicators, require(v))
	end
	return replicators
end

function ReplicationService:AddSecurityLibrary(securitylibrary: "instance")
	if securitylibrary ~= nil and securitylibrary:IsA("ModuleScript") then
		local newlibrary = securitylibrary:Clone()
		newlibrary.Parent = security_libraries
	end
end

function ReplicationService:RemoveSecurityLibrary(securitylibrary: "string")
	if security_libraries:FindFirstChild(securitylibrary) then
		security_libraries:FindFirstChild(securitylibrary):Destroy()
	end
end


return ReplicationService
